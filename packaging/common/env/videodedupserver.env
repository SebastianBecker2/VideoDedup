# Environment overrides for VideoDedupServer (systemd EnvironmentFile).
# Syntax: KEY=value  (# comments and blank lines allowed)
#
# Packaged Linux server uses HTTP/2 cleartext (gRPC h2c) on [::]:51726 (dual-stack; IPv4 + IPv6) — no server.pfx in the .deb.
# Configure the Windows client: protocol http, this host's address, port 51726 (or TLS via a reverse proxy).
#
# Firewall: packages do not open TCP 51726 automatically. See:
#   /usr/share/doc/videodedupserver/README.firewall
# Helper scripts (run one as root, matching your stack):
#   /usr/lib/videodedupserver/firewall/configure-firewall-interactive.sh
#   /usr/lib/videodedupserver/firewall/open-port-ufw.sh
#   /usr/lib/videodedupserver/firewall/open-port-firewalld.sh
#   /usr/lib/videodedupserver/firewall/open-port-iptables.sh
#   /usr/lib/videodedupserver/firewall/open-port-nftables.sh
# Optional persistence (nft/iptables): sudo <script> --persist  (see README.firewall)

# Writable application data (settings, logs, SQLite, etc.)
VIDEODEDUP_APP_DATA=/var/lib/videodedupserver

# Optional: directory containing libav* shared libraries if FFmpeg.AutoGen cannot resolve system libs.
# Leave unset to use the dynamic linker default paths (typical when ffmpeg packages are installed).
#VIDEODEDUP_FFMPEG_LIB_ROOT=/usr/lib/x86_64-linux-gnu

# Refuse root unless explicitly debugging (set to 1 only temporarily).
#VIDEODEDUP_ALLOW_ROOT=0
